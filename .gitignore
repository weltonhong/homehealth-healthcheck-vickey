# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/

# Health check temp data (generated each run)
**/temp_health_check.json
**/temp_*.json

# Cookie cache from local Playwright runs (Streamlit Cloud doesn't use it)
**/.google_cookies.json

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# GitHub Codespaces auto-generated devcontainer (broke Brian's deploy when
# GitHub's wizard wrote postAttachCommand pointing at google_serp_rank.py
# instead of webapp/app.py — Streamlit Cloud picked up that hint and
# crash-looped on argparse). Block at source.
.devcontainer/

# Secrets - never commit
.env
.streamlit/secrets.toml
*.key
